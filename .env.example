# Optional LiteLLM proxy endpoint
LITELLM_BASE_URL=http://127.0.0.1:4000
LITELLM_API_KEY=
LITELLM_TIMEOUT_MS=45000

# Direct provider keys (used when LiteLLM is not running)
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=

# Stage-level provider routing
MODEL_PROVIDER_SPEC_BUILDER=deepseek
MODEL_PROVIDER_PLANNER=deepseek
MODEL_PROVIDER_GENERATOR=gemini
MODEL_PROVIDER_VERIFIER=gemini
MODEL_PROVIDER_REPAIRER=deepseek
MODEL_PROVIDER_FINALIZER=deepseek

# Optional explicit model overrides
MODEL_NAME_SPEC_BUILDER=deepseek/deepseek-chat
MODEL_NAME_PLANNER=deepseek/deepseek-chat
MODEL_NAME_GENERATOR=gemini/gemini-2.5-flash
MODEL_NAME_VERIFIER=gemini/gemini-2.5-flash
MODEL_NAME_REPAIRER=deepseek/deepseek-chat
MODEL_NAME_FINALIZER=deepseek/deepseek-chat

# Optional fallback chains, comma-separated
MODEL_FALLBACKS_SPEC_BUILDER=gemini/gemini-2.5-flash,deepseek/deepseek-chat
MODEL_FALLBACKS_PLANNER=gemini/gemini-2.5-flash,deepseek/deepseek-chat
MODEL_FALLBACKS_GENERATOR=deepseek/deepseek-chat,gemini/gemini-2.5-flash
MODEL_FALLBACKS_VERIFIER=deepseek/deepseek-chat,gemini/gemini-2.5-flash

